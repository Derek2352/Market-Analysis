# Salt used to hash author identifiers. Keep this private.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
AUTHOR_HASH_SALT=replace-me-with-a-long-random-string

# Set to 1 to opt into network-hitting integration tests.
# SCRAPE_LIVE_TESTS=1

# --- Phase 4: LLM synthesis (required for `mkt synthesize`) ---
# This is the project's single paid-service exception, justified because
# Claude is used for synthesis (output), not for data collection (input).
# Get your key at: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...
# Optional model override (default: claude-sonnet-4-20250514):
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
